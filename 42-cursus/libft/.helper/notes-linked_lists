9.2 LA SOLUZIONE
Salvo next prima di cancellare:

C


void ft_lstclear(t_list **lst, void (*del)(void *))
{
    t_list *tmp;

    if (!lst || !del)
        return;
    while (*lst)
    {
        tmp = (*lst)->next;      // Salvo il prossimo
        ft_lstdelone(*lst, del); // Cancello il corrente
        *lst = tmp;              // Vado avanti
    }
    *lst = NULL;
}
