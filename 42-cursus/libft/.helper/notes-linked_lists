11.2 LA FUNZIONE
C


t_list *ft_lstmap(t_list *lst, void *(*f)(void *), void (*del)(void *))
{
    t_list *new_list;
    t_list *new_node;
    void *new_content;

    if (!lst || !f || !del)
        return (NULL);
    new_list = NULL;
    while (lst)
    {
        new_content = f(lst->content);           // Applico f
        new_node = ft_lstnew(new_content);       // Creo nuovo nodo
        if (!new_node)                           // Se fallisce...
        {
            del(new_content);                    // Pulisco
            ft_lstclear(&new_list, del);         // Pulisco tutto
            return (NULL);
        }
        ft_lstadd_back(&new_list, new_node);     // Aggiungo alla nuova lista
        lst = lst->next;                         // Vado avanti
    }
    return (new_list);
}
